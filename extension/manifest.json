{
  "manifest_version": 3,
  "name": "Unfugly",
  "version": "2.0.03",
  "description": "Revamp your Academia with a unified dashboard and Auto-generates a downloadable timetable",
  "permissions": [
    "cookies",
    "storage"
  ],
  "host_permissions": [
    "https://srmist.edu.in/*",
    "https://*.srmist.edu.in/*",
    "https://creatorapp.zoho.com/srm_university/*",
    "https://unfugly-backend.onrender.com/*",
    "https://zoho.in/*",
    "https://*.zoho.in/*",
    "https://zoho.com/*",
    "https://*.zoho.com/*",
    "https://*.zohocdn.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://academia.srmist.edu.in/*", "https://creatorapp.zoho.com/srm_university/*"],
      "js": ["utils/logger.js", "lib/html2canvas.min.js", "api/courseRegistration.js", "api/unifiedTimetable.js", "api/attendance.js", "api/calendar.js", "analytics.js", "content.js", "editTimetable.js", "predict.js", "imageURLScript.js"],
      "css": ["styles.css"]
    },
    {
      "matches": ["https://www.srmist.edu.in/staff-finder/*"],
      "js": ["staffFinderAssistant.js"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "images/icon16.png",
    "32": "images/icon32.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon16.png",
      "32": "images/icon32.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  },
  "web_accessible_resources": [  
    {
      "resources": ["images/*"],
      "matches": ["<all_urls>"] 
    }
  ]
}
