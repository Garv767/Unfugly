{
  "manifest_version": 3,
  "name": "Unfugly",
  "version": "1.10.0",
  "description": "Revamp your Academia with a unified dashboard and Auto-generates a downloadable timetable",
  "permissions": [
    "cookies",
    "storage"
  ],
  "host_permissions": [
    "https://*.srmist.edu.in/*",
    "https://creatorapp.zoho.com/srm_university/*",
    "https://unfugly-backend.onrender.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://academia.srmist.edu.in/*", "https://creatorapp.zoho.com/srm_university/*"],
      "js": ["lib/html2canvas.min.js", "api/courseRegistration.js", "api/unifiedTimetable.js", "api/attendance.js", "api/calendar.js", "analytics.js", "content.js", "editTimetable.js", "predict.js", "imageURLScript.js"],
      "css": ["styles.css"]
    },
    {
      "matches": ["https://www.srmist.edu.in/staff-finder/*"],
      "js": ["staffFinderAssistant.js"]
    }
  ],
  "background": [
    {
      "service_worker": "background.js"
    }
  ],
  "icons": {
    "16": "images/icon16.png",
    "32": "images/icon32.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "web_accessible_resources": [  
    {
      "resources": ["images/*"],
      "matches": ["<all_urls>"] 
    }
  ]
}
